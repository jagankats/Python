print("\n🔥 1. LONGEST CONSECUTIVE SEQUENCE")

def longest_consecutive(nums):
    num_set = set(nums)
    longest = 0

    for num in num_set:
        if num - 1 not in num_set:
            current = num
            length = 1

            while current + 1 in num_set:
                current += 1
                length += 1

            longest = max(longest, length)
    return longest

nums = [100,4,200,1,3,2]
print("Input:", nums)
print("Output:", longest_consecutive(nums))
print("Explanation: Sequence is [1,2,3,4] → length = 4")

