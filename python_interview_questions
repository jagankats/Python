print("\n🔥 8. FIRST NON-REPEATING CHARACTER")

def first_unique(s):
    #count_chars = Counter(s)
    count_chars = {}
    for char in s:
        if char in count_chars:
            count_chars[char] += 1
        else:
            count_chars[char] = 1
    for ch in s:
        if count_chars[ch] == 1:
            return ch
    return None

s = "swiss"
print("Input:", s)
print("Output:", first_unique(s))
print("Explanation: 'w' appears once")


