print("\n🔥 3. UNIQUE PAIRS (SUM = TARGET)")

def unique_pairs(nums, target):
    seen = set()
    pairs = set()

    for num in nums:
        diff = target - num
        if diff in seen:
            pairs.add(tuple(sorted((num, diff))))
        seen.add(num)

    return list(pairs)

nums = [1,2,3,2,4]
target = 5
print("Input:", nums, "Target:", target)
print("Output:", unique_pairs(nums, target))
print("Explanation: Pairs are (1,4) and (2,3)")


