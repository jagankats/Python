from collections import Counter

def most_frequent(nums):
    return Counter(nums).most_common(1)[0][0]

nums = [1,3,2,1,4,1,3]
print("Input:", nums)
print("Output:", most_frequent(nums))
print("Explanation: 1 appears most frequently")


