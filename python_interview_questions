print("\n🔥 6. MULTITHREADING")

import threading
import time

def task(name):
    print(f"Start {name}")
    time.sleep(1)
    print(f"End {name}")

t1 = threading.Thread(target=task, args=("Thread-1",))
t2 = threading.Thread(target=task, args=("Thread-2",))

t1.start()
t2.start()

t1.join()
t2.join()

print("Explanation: Threads run concurrently (good for I/O tasks)")


