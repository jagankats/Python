print("\n🔥 4. FLATTEN NESTED LIST")
from collections import Counter
def flatten(lst):
    result = []
    for item in lst:
        if isinstance(item, list):
            result.extend(flatten(item))
        else:
            result.append(item)
    return result

lst = [1,[2,[3,4],5],6]
print("Input:", lst)
print("Output:", flatten(lst))
print("Explanation: Nested list flattened")



