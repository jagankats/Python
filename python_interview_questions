print("\n🔥 10. BINARY SEARCH")

def binary_search(nums, target):
    left, right = 0, len(nums)-1

    while left <= right:
        mid = (left + right)//2

        if nums[mid] == target:
            return mid
        elif nums[mid] < target:
            left = mid + 1
        else:
            right = mid - 1
    return -1

nums = [1,2,3,4,5]
target = 4
print("Input:", nums, "Target:", target)
print("Output:", binary_search(nums, target))
print("Explanation: Found at index 3")


