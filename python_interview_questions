print("\n🔥 12. TWO SUM")

def two_sum(nums, target):
    lookup = {}
    for i, num in enumerate(nums):
        diff = target - num
        if diff in lookup:
            return [lookup[diff], i]
        lookup[num] = i

nums = [2,7,11,15]
target = 9
print("Input:", nums, "Target:", target)
print("Output:", two_sum(nums, target))
print("Explanation: 2 + 7 = 9 → indices [0,1]")

