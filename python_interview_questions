print("\n🔥 11. LONGEST SUBSTRING WITHOUT REPEATING")

def longest_unique(s):
    seen = set()
    left = 0
    max_len = 0

    for right in range(len(s)):
        while s[right] in seen:
            seen.remove(s[left])
            left += 1
        seen.add(s[right])
        max_len = max(max_len, right-left+1)

    return max_len

s = "abcabcbb"
print("Input:", s)
print("Output:", longest_unique(s))
print("Explanation: Longest substring is 'abc' → length 3")


